# Скопируй этот файл в .env и задай свои значения.
# .env НЕ надо загружать в GitHub.

ADMIN_USERNAME=Samandar2212
ADMIN_PASSWORD=change-me-local-password
AUTH_SECRET=change-me-long-random-secret
AUTH_ALLOW_REGISTRATION=1
AUTH_USERS_FILE=data/dashboard_users.json
AUTH_ACCESS_REQUESTS_FILE=data/access_requests.json
AUTH_SECURITY_EVENTS_FILE=data/security_events.json
BOT_TOKEN=your-new-telegram-bot-token
WEBAPP_URL=https://your-dashboard-url.example.com
TELEGRAM_WEBHOOK_SECRET=change-me-random-webhook-secret

# SERVER ONLY. Никогда не добавляй эти значения в VITE_* или frontend/.env.
# Используй новый restricted/auth key и отзови любой ключ, который уже был в коде.
GEMINI_API_KEY=replace-with-server-side-gemini-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_TIMEOUT_SECONDS=30
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_CHAT_REQUESTS_PER_MINUTE=20
