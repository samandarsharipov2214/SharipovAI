# Public hostname pointed to this VPS. Do not include https://.
DOMAIN=sharipovai.example.com

# Dashboard security. AUTH_SECRET >= 32 chars; ADMIN_PASSWORD >= 14 chars.
ENVIRONMENT=production
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ADMIN_USERNAME=replace-admin-name
ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_TTL_SECONDS=1209600
SHARIPOVAI_DISABLE_AUTH=0

# Telegram interface and critical alerts.
BOT_TOKEN=
WEBAPP_URL=https://sharipovai.example.com
TELEGRAM_WEBAPP_URL=https://sharipovai.example.com
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
ALERT_DELIVERY_ENABLED=0
CRITICAL_ALERT_MONITOR_ENABLED=1
CRITICAL_ALERT_MONITOR_SECONDS=15
CRITICAL_ALERT_REPEAT_SECONDS=900

# Bybit read-only account credentials.
BYBIT_READONLY_API_KEY=
BYBIT_READONLY_API_SECRET=
BYBIT_ACCOUNT_BASE_URL=https://api.bybit.com
BYBIT_ACCOUNT_SYNC_ENABLED=1

# Execution credentials are never stored in this production-safe file.
# Use .env.testnet-campaign for isolated Testnet credentials during an authorized window.
BYBIT_ALLOW_LEGACY_EXCHANGE_CREDENTIALS=0

# Public read-only market stream.
FEATURE_BYBIT_WEBSOCKET=1
BYBIT_WS_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
BYBIT_WS_MAX_QUOTE_AGE_SECONDS=2.5

# Production-safe baseline. Never edit these locks for a campaign.
# testnet_campaign_deploy.sh applies a separate, explicit .env.testnet-campaign overlay.
EXCHANGE_MODE=sandbox
EXCHANGE_BASE_URL=https://api-testnet.bybit.com
EXCHANGE_LIVE_TRADING_ENABLED=0
FEATURE_BYBIT_LIVE_EXECUTION=0
EXECUTION_KILL_SWITCH=1
TESTNET_EXECUTION_ENABLED=0
AUTONOMOUS_TESTNET_ENABLED=0
AUTONOMOUS_TESTNET_BRIDGE_ENABLED=0
FEATURE_BYBIT_TESTNET=0
FEATURE_BYBIT_PRIVATE_ORDER_WS=0
RUNTIME_FILL_HARVESTER_ENABLED=0
SCHEDULED_CAMPAIGN_ORCHESTRATOR_ENABLED=0
PHASE6_TESTNET_RELEASE_GATE=blocked
EXECUTION_MAX_NOTIONAL_USDT=25
SHADOW_TESTNET_MAX_NOTIONAL_USDT=25
CAMPAIGN_ORCHESTRATOR_TICK_SECONDS=10
BYBIT_PRIVATE_WS_GATE_MAX_AGE_SECONDS=60

# Release metadata injected by the deployment script/CI when available.
SHARIPOVAI_RELEASE_SHA=unknown
SHARIPOVAI_RELEASE_TAG=local
SHARIPOVAI_BUILD_DATE=unknown
