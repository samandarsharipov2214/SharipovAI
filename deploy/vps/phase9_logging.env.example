# Phase 9 structured runtime logging. Never place secrets in log fields.
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_INCLUDE_TIMESTAMP=1
LOG_REDACT_HEADERS=authorization,cookie,x-api-key
LOG_MAX_FIELD_LENGTH=2048
LOG_REQUEST_BODY=0
LOG_RESPONSE_BODY=0
PHASE9_VERIFY_REPORT=/var/lib/sharipovai/deploy/phase9-verify.json
PHASE9_HEALTH_URL=http://127.0.0.1:8000/health
