# Public frontend configuration only.
# Never put GEMINI_API_KEY, GOOGLE_API_KEY, exchange keys, tokens or passwords here.

# Empty means same-origin /api requests in production.
VITE_API_BASE_URL=

# Development-only Vite proxy target. This value is read by vite.config.ts,
# not by browser application code.
DEV_API_PROXY_TARGET=http://127.0.0.1:8000
